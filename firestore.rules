rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Check if user exists and has one of the allowed roles
    function hasRole(roles) {
      return isAuthenticated() && (
        (request.auth.token.role in roles) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role in roles)
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'admin' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isStaff() {
      return hasRole(['admin', 'manager', 'sales_executive', 'project_manager']);
    }

    function isEditor() {
      return hasRole(['editor']);
    }

    // --- Collection Rules ---

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Allow creation (e.g. sign up)
      allow update: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin() ||
        // PM can update clients they directly manage (matched via either assignment field)
        (hasRole(['project_manager']) && (
          resource.data.managedByPM == request.auth.uid ||
          resource.data.assignedManagerId == request.auth.uid
        )) ||
        // Any PM can write ONLY the safe editor-config fields on a client document.
        // This allows saving auto-assign priorities regardless of which PM field is set.
        (hasRole(['project_manager']) &&
          resource.data.role == 'client' &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['assignedEditorPriority', 'defaultEditorRate'])
        )
      );
      allow delete: if isAdmin() || hasRole(['project_manager']);
    }

    // 2. Projects Collection
    match /projects/{projectId} {
      allow create: if isAuthenticated();
      
      allow read: if true; // Allow public sharing via link (trusting UUID)

      allow update: if isAuthenticated() && (
        isStaff() ||
        resource.data.assignedEditorId == request.auth.uid ||
        (resource.data.members is list && request.auth.uid in resource.data.members) ||
        resource.data.clientId == request.auth.uid ||
        resource.data.ownerId == request.auth.uid
      ) &&
      !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['editorPaid', 'editorPaidAt', 'completedAt']) &&
      (
        request.resource.data.status == resource.data.status ||
        request.resource.data.status != 'completed'
      );
      
      allow delete: if isAdmin() || hasRole(['project_manager']);
      
      // Chat Subcollection
      match /chat/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }

    // 3. Invoices Collection
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated() && (
        isStaff() || 
        resource.data.clientId == request.auth.uid
      );
      allow create, update: if isStaff();
      allow delete: if isAdmin() || hasRole(['project_manager']);
    }

    // 4. Revisions Collection
    match /revisions/{revisionId} {
      allow read: if true; // Allow public sharing via link
      
      allow create, update: if isAuthenticated() && (
        isStaff() ||
        isEditor() ||
        get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.assignedEditorId == request.auth.uid ||
        (get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.members is list &&
          request.auth.uid in get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.members)
      );

       allow delete: if isAdmin() || isStaff();
    }

    // 5. Comments Collection
    match /comments/{commentId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAuthenticated() || (
        // Allow guest users (unauthenticated) to reply, submit notifications, or edit their own guest comments
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies', 'notificationSubmitted', 'notificationSubmittedAt'])
      ) || (
        resource.data.userId == 'guest' &&
        resource.data.userRole == 'guest' &&
        request.resource.data.userId == 'guest' &&
        request.resource.data.userRole == 'guest'
      );
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || // Creator of the comment
        isAdmin() || isStaff() || isEditor() || // Admin/staff/editor roles
        resource.data.projectId != null && (
          get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.assignedEditorId == request.auth.uid ||
          get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.assignedPMId == request.auth.uid ||
          get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.clientId == request.auth.uid ||
          get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.ownerId == request.auth.uid
        )
      );
    }

    // 6. Settings Collection (Agency Branding, etc)
    match /settings/{docId} {
      allow read, write: if true;
    }

    // 7. Upload Sessions (chunked upload state)
    match /upload_sessions/{sessionId} {
      allow read: if isAuthenticated() && (
        isStaff() ||
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.ownerId == request.auth.uid ||
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.clientId == request.auth.uid ||
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.assignedEditorId == request.auth.uid ||
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.assignedPMId == request.auth.uid
      );

      allow create: if isAuthenticated() && (
        isStaff() ||
        get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.ownerId == request.auth.uid ||
        get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.clientId == request.auth.uid ||
        get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.assignedEditorId == request.auth.uid ||
        get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.assignedPMId == request.auth.uid
      );

      allow update: if isAuthenticated() && (
        isStaff() ||
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.ownerId == request.auth.uid ||
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.clientId == request.auth.uid ||
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.assignedEditorId == request.auth.uid ||
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.assignedPMId == request.auth.uid
      );

      allow delete: if isAdmin();
    }

    // 8. Video Jobs (thumbnail/transcode processing status)
    match /video_jobs/{jobId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Default deny for anything else
    match /{document=**} {
      allow read, write: if false; 
    }
  }
}
